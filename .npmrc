# The project depends on the OpenAI v4 SDK (openai@^4) for the OpenAI-compatible
# chat path. openai@4 declares peerOptional zod@^3.23.8, which the zod 4 upgrade
# (Phase 3a) does not satisfy — npm then refuses to resolve without this flag.
# The conflict is benign: openai@4's zod usage (structured-output helpers) is not
# on NeuroClaw's path, and the suite + build pass under zod 4. The openai SDK is
# slated for replacement in the native-backend migration; revisit removing this
# once that lands (or once openai is bumped to v6, which peer-allows zod 4).
legacy-peer-deps=true
