# crawl4ai agent — needs Playwright + Chromium.
# Built from the official Playwright Python image to avoid manual browser/system
# dependency wrangling.

FROM mcr.microsoft.com/playwright/python:v1.60.0-jammy AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install -r /app/requirements.txt

COPY . /app

ENV PYTHONPATH=/app HOST=0.0.0.0 \
    AGENT_MODULE=crawl4ai_agent.agent \
    PORT=7105

# crawl4ai's first run normally fetches model assets / does browser setup.
# Pre-warm here so container start is fast and offline-safe.
RUN python -c "from crawl4ai import AsyncWebCrawler" || true

ENTRYPOINT ["python", "-u", "/app/docker/launcher.py"]
