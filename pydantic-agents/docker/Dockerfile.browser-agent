# browser-agent — agent-browser CLI + Python fastmcp server.
#
# Needs Node.js (agent-browser is an npm package), Python (fastmcp server),
# and Chrome runtime libraries (agent-browser downloads Chrome for Testing).

FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

# ── System deps ───────────────────────────────────────────────────────────────
# Node.js 20 (for agent-browser) + Chrome runtime libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates gnupg \
    # Chrome runtime dependencies
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    libgbm1 libasound2 libpango-1.0-0 libcairo2 libnspr4 libx11-6 \
    libxext6 libxss1 libxcb1 libx11-xcb1 fonts-liberation wget \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── agent-browser CLI ─────────────────────────────────────────────────────────
# Install globally; the `install` subcommand downloads Chrome for Testing.
# AGENT_BROWSER_NO_SANDBOX=1 needed when running as root inside Docker.
ENV AGENT_BROWSER_NO_SANDBOX=1
RUN npm install -g agent-browser \
    && agent-browser install --chrome

# ── Python deps ───────────────────────────────────────────────────────────────
WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install -r /app/requirements.txt

COPY . /app

ENV PYTHONPATH=/app \
    HOST=0.0.0.0 \
    AGENT_MODULE=browser_agent.agent \
    PORT=7107

ENTRYPOINT ["python", "-u", "/app/docker/launcher.py"]
