# Shared LLM key — these agents call OpenAI-compatible endpoints just like NeuroClaw.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.voidai.app/v1
PYDANTIC_AGENT_MODEL=gpt-5.1

# Per-agent ports — must match what NeuroClaw registers in mcp_servers
PYDANTIC_DEEP_RESEARCH_PORT=7100
PYDANTIC_WEB_RESEARCH_PORT=7101
PYDANTIC_IMAGE_AGENT_PORT=7106
# optional: set to override the default outputs directory (pydantic-agents/image_agent/outputs/)
IMAGE_AGENT_OUTPUT_DIR=

# Gemini web agent (Nano Banana / Imagen + Lyra audio)
GEMINI_WEB_AGENT_PORT=7111
# optional: override default profile/output dirs
GEMINI_PROFILE_DIR=
GEMINI_IMAGE_OUTPUT_DIR=
GEMINI_AUDIO_OUTPUT_DIR=
# set to "false" to show the browser window (debugging)
GEMINI_HEADLESS=true

# Grok image agent (xAI vision + generation pipeline)
GROK_IMAGE_AGENT_PORT=7112
# optional: override the default outputs directory (pydantic-agents/grok_image_agent/outputs/)
GROK_IMAGE_OUTPUT_DIR=

# Tool API keys
TAVILY_API_KEY=

# Image delivery — local serving
# Set both to enable local_url in image agent responses
# NEUROCLAW_UPLOADS_DIR=/home/neuroclaw-v1/uploads
# NEUROCLAW_DASHBOARD_URL=http://localhost:3141

# Image delivery — Supabase public URLs
# Set all three to enable public_url in image agent responses
# See docs/superpowers/specs/2026-05-23-image-delivery-design.md for setup steps
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
# SUPABASE_IMAGES_BUCKET=neuroclaw-images
