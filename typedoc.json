{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/config.ts",
    "src/db.ts",
    "src/agent/alfred.ts",
    "src/agent/openai-client.ts",
    "src/agent/anthropic-client.ts",
    "src/tools/registry.ts",
    "src/tools/schemas.ts",
    "src/tools/context.ts",
    "src/memory/memory-pipeline.ts",
    "src/memory/memory-retriever.ts",
    "src/memory/context-compactor.ts",
    "src/mcp/mcp-registry.ts",
    "src/mcp/mcp-client.ts",
    "src/system/spawner.ts",
    "src/system/router.ts",
    "src/system/model-triage.ts",
    "src/dashboard/server.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "name": "NeuroClaw API Reference",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeInternal": true,
  "skipErrorChecking": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Core", "Agents", "Memory", "Tools", "MCP", "System", "*"],
  "navigationLinks": {
    "Wiki": "/dashboard?token=TOKEN#/docs",
    "GitHub": "https://github.com/anomalyco/neuroclaw-v1"
  },
  "githubPages": false,
  "hideGenerator": true,
  "searchInComments": true,
  "cleanOutputDir": true
}
