{
  "permissions": {
    "allow": [
      "Read(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(echo*)",
      "Bash(which*)",
      "Bash(npm run*)",
      "Bash(npx tsc*)",
      "Bash(node --version*)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(curl *)"
    ],
    "deny": []
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/neuroclaw-v1/scripts/approval-hook.js"
          }
        ]
      }
    ]
  }
}
