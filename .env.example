VOIDAI_API_KEY=sk-voidai-your-key
# Optional: separate API key for background/system work (heartbeat, memory extraction,
# dream cycle, decomposer, router). Routes scheduled calls to a different rate-limit
# bucket so they don't compete with foreground chat. Falls back to VOIDAI_API_KEY when unset.
# Preferred: store as broker secret SHARED_VOIDAI_BG_KEY via the dashboard Secrets tab.
# Direct .env override (takes precedence over broker):
# VOIDAI_BG_API_KEY=sk-voidai-your-background-key
VOIDAI_BASE_URL=https://api.voidai.app/v1
VOIDAI_MODEL=gpt-5.1

# ── Background model routing (decomposer, memory extractor, dream cycle, ──────
# context compactor, user profiler, session namer, holdout reviewer, skill forge)
# These calls go through bgChatCompletion(): VoidAI claude-haiku-4-5 FIRST, then
# the OpenRouter model below as the backup on any error/timeout.
# BG_VOIDAI_FIRST=false reverts everything to OpenRouter-primary (no VoidAI try).
# BG_MODEL is the single OpenRouter backup model for every gemini-tier background
# task (gemini-3.5-flash). BG_PROVIDER stays 'openrouter'.
# BG_PROVIDER=openrouter
# BG_MODEL=google/gemini-3.5-flash
# BG_VOIDAI_FIRST=true
# Default VoidAI bg model is claude-haiku-4-5: ~1-2s and reliable. Every VoidAI
# gemini is far slower (2.5-flash reasons ~8-40s, 3.5-flash ~55s) and the OpenAI
# minis were flaky/slow. Override only if you have a faster VoidAI model.
# BG_VOIDAI_MODEL=claude-haiku-4-5-20251001
# reasoning_effort/min_tokens only matter for reasoning models (e.g. if you set
# BG_VOIDAI_MODEL to a gemini): they floor the budget and cap thinking so small
# callers (the 20-token namer) still get content. No-ops for haiku.
# BG_VOIDAI_REASONING_EFFORT=low
# BG_VOIDAI_MIN_TOKENS=512
# Per-attempt VoidAI timeout (ms). Generous by default since the OpenRouter
# fallback only helps when that account has credit. Lower once OpenRouter is funded.
# BG_VOIDAI_TIMEOUT_MS=90000

DASHBOARD_PORT=3141
DASHBOARD_TOKEN=change-me

# ── Cookie Sync server (AI Cookie Sync Chrome extension) ──────────────────────
# Separate server bound to 0.0.0.0 so the Chrome extension on your local
# machine can push fresh cookies to this server automatically.
# Uses the same DASHBOARD_TOKEN for auth. Open port 3143 in your firewall.
COOKIE_SYNC_PORT=3143

DB_PATH=./neuroclaw.db

# Auto-delegation: LLM classifies which agent best fits each message
AUTO_DELEGATION_ENABLED=false
AUTO_DELEGATION_MIN_CONFIDENCE=0.65
ROUTER_MODEL=

# Temporary agent spawning
SPAWN_AGENTS_ENABLED=false
TEMP_AGENTS_AUTO_APPROVE=true
TEMP_AGENT_TTL_HOURS=6
TEMP_AGENT_IDLE_TIMEOUT_MINUTES=30
TEMP_AGENT_SOFT_LIMIT=10
TEMP_AGENT_HARD_LIMIT=25

# Claude / Anthropic integration
# Backend selector: "claude-cli" (default) routes Claude calls through the local
# `claude` CLI (subscription auth, no API key needed). "anthropic-api" uses the
# direct Anthropic SDK + ANTHROPIC_API_KEY (billed per-token).
# There is NO silent fallback between them.
CLAUDE_BACKEND=claude-cli
CLAUDE_CLI_COMMAND=claude
# Long-running turn liveness (project: Jarvis long-run triage). Two-layer abort
# on BOTH backends: an idle watchdog (PRIMARY — aborts only on genuine silence
# with no tool in flight; graceful report-back) and an absolute wall-clock
# backstop (fires regardless, generous so legit long Forge builds aren't cut).
# The session queue auto-derives ABOVE these ceilings (config.queue) so it can't
# reject a turn the backend is still working. Set SESSION_QUEUE_TIMEOUT_MS only
# to decouple the queue from the derived ceiling.
CLAUDE_TIMEOUT_MS=2700000               # absolute backstop, claude plane (45 min)
CLAUDE_IDLE_ABORT_MS=300000             # genuine silence → graceful bail (5 min)
OPENAI_AGENTS_ABSOLUTE_MAX_MS=2700000   # absolute backstop, backbone (45 min)
# SESSION_QUEUE_TIMEOUT_MS=             # unset ⇒ auto-derive (max ceiling + 2 min)

CLAUDE_RETRY_MAX=2
CLAUDE_RETRY_BASE_MS=3000

# Required only when CLAUDE_BACKEND=anthropic-api. Get from https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ── OpenAI (direct API) ──────────────────────────────────────────────────
# Optional: used for embeddings when MEMORY_EMBEDDING_MODEL is an OpenAI model
# (e.g. text-embedding-3-small). Falls back to VoidAI when unset.
OPENAI_API_KEY=

# ── Codex (OpenAI / ChatGPT subscription via local `codex` CLI) ───────────
# Backend selector: "cli" (default) routes through your local `codex` binary
# using the ChatGPT subscription credentials at ~/.codex/auth.json.
# "api" uses OPENAI_API_KEY directly via the OpenAI SDK (per-token billing).
# "app-server" runs a persistent `codex app-server` JSON-RPC backend that gives
# Codex agents full in-process NeuroClaw tool access (memory/skills/agent calls/
# vault) via dynamicTools + token-by-token streaming + session continuity.
CODEX_BACKEND=cli   # cli | app-server | api
CODEX_CLI_COMMAND=codex
CODEX_TIMEOUT_MS=900000
CODEX_CONCURRENCY_LIMIT=1
# Sandbox policy when Codex executes shell commands (read-only is safest).
# Allowed: read-only | workspace-write | danger-full-access
CODEX_SANDBOX_MODE=read-only

# ── Opencode CLI (local binary auth via `opencode` CLI) ───────────────────
# Set provider=opencode on the agent to route via the local `opencode` binary.
OPENCODE_CLI_COMMAND=opencode
OPENCODE_MODEL=opencode-latest
OPENCODE_TIMEOUT_MS=900000
OPENCODE_CONCURRENCY_LIMIT=1

# ── Kimi Code API (key-based, OpenAI-compatible) ────────────────────────────
# Set provider=kimi-api on the agent to route through the Kimi Code API.
# Get an API key from https://www.kimi.com/code — up to 5 keys per account.
# Sub-agent routing: code tasks → kimi-api (Kimi K2.6 cloud)
# KIMI_API_KEY=km-...
# KIMI_API_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_API_MODEL=kimi-k2-6

# ── OpenRouter (multi-model routing proxy) ────────────────────────────────
# OpenRouter provides access to many AI models through a single API.
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model when creating new agents with provider=openrouter.
# Format: provider/model-name (e.g., anthropic/claude-sonnet-4, openai/gpt-4o)
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Venice (privacy-first, OpenAI-compatible — https://venice.ai/settings/api)
# VENICE_API_KEY=
# VENICE_BASE_URL=https://api.venice.ai/api/v1
# VENICE_MODEL=zai-org-glm-5-1

# ── Abacus AI / RouteLLM (OpenAI-compatible, used for its media models)
# Set ABACUS_API_KEY to enable. The full model list (incl. media models) is
# pulled from the standard /v1/models endpoint into the model catalog.
# ABACUS_API_KEY=
# ABACUS_BASE_URL=https://routellm.abacus.ai/v1
# ABACUS_MODEL=gpt-5

# ── Pollinations AI (heartbeat pings — free, OpenAI-compatible — https://gen.pollinations.ai) ──
# Used for connectivity health checks; keeps VoidAI quota for real agent work.
# Anonymous tier works (1 req/15s). Free Seed account raises limit (1 req/5s): https://auth.pollinations.ai
# POLLINATIONS_API_KEY=          # optional Bearer token; omit for anonymous
# POLLINATIONS_BASE_URL=https://gen.pollinations.ai

# ── Perplexity Web MCP (research layer via browser session — https://perplexity.ai) ────
# Get tokens: DevTools → Application → Cookies on perplexity.ai
# PERPLEXITY_SESSION_TOKEN=   # value of __Secure-next-auth.session-token cookie
# PERPLEXITY_CSRF_TOKEN=      # value of next-auth.csrf-token cookie
# PERPLEXITY_MCP_URL=         # optional override; default: http://127.0.0.1:7205/sse
# Sonar Smart — auto-routes to fast/deep/reason mode (deploy sonar-smart container first)
# SONAR_SMART_ENABLED=true    # set true after: cd /home/pydantic-compose/sonar-smart && docker compose up -d --build
# SONAR_SMART_MCP_URL=        # optional override; default: http://127.0.0.1:7207/mcp

# ── Venice Image MCP (image generation via Venice AI subscription — https://venice.ai) ──
# NOTE: distinct from VENICE_API_KEY above — this uses a browser session token, not an API key.
# Get token: DevTools → Network tab on venice.ai → find any api.venice.ai request → copy Authorization Bearer value
# VENICE_SESSION_TOKEN=        # Bearer token from venice.ai DevTools Network tab
# VENICE_IMAGE_MCP_URL=        # optional override; default: http://127.0.0.1:7206/mcp

# ── Ollama (local LLM server — no API key required) ─────────────────────────
# Run a local Ollama instance and point NeuroClaw to it.
# Download Ollama at https://ollama.ai, then run `ollama serve` locally.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
# Set to false to strip the tools array from Ollama requests. Useful for local
# models that don't support function calling and fail with "Premature close"
# when a tools payload is sent. Cloud models (e.g. kimi-k2) support tools and
# work correctly with the default (true).
# OLLAMA_TOOLS_ENABLED=false
# Expand the context window beyond Ollama's default (2048–4096 tokens).
# Tool schemas + system prompt alone can consume the default budget, causing
# truncated prompts and hallucinated / missing tool calls. 16384 is a safe
# baseline for most modern models. Set to 0 to use Ollama's own default.
# OLLAMA_NUM_CTX=16384
# Retries for transient server errors (503 capacity) and premature-close drops.
# Applies to both the connection attempt and the stream. Backoff is exponential.
# OLLAMA_RETRY_MAX=2
# OLLAMA_RETRY_BASE_MS=1500

# ── LiteLLM (OpenAI-compatible proxy / model gateway) ─────────────────────
# Point any LiteLLM proxy (local or hosted) for unified multi-provider access.
# No API key required if the proxy is open; set it when your proxy enforces auth.
# Sub-agent routing: all non-code tasks → litellm (MiniMax 2.7)
# LITELLM_API_KEY=
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_MODEL=MiniMax-M2.7
# Set LITELLM_TOOLS_ENABLED=false when the upstream (e.g. Literouter) strips the tools array.
# Then enable LITELLM_TEXT_TOOLS_ENABLED=true to activate the text-mode tool harness:
# tool schemas are injected into the system prompt and <tool_call>…</tool_call> responses are parsed.
# LITELLM_TOOLS_ENABLED=false
# LITELLM_TEXT_TOOLS_ENABLED=false

# Sub-agent model routing — NATIVE gateways (two-provider system):
#   code tasks → kimi    (Kimi for Coding, Moonshot — OpenAI-compatible)
#   everything → minimax (MiniMax direct — OpenAI-compatible)
# Both reuse the main-agent keys (KIMI_ANTHROPIC_KEY / MINIMAX_ANTHROPIC_KEY).
# Trade-off: coding sub-agents now share the Moonshot quota with the main Kimi
# agents (Jarvis/FRIDAY) — watch the Kimi 5h/weekly usage window.
#
# Kimi for Coding route. The /coding endpoint gates by client identity, so a
# recognized coding-agent User-Agent is required (plain SDK requests get 403).
# SUBAGENT_KIMI_BASE_URL=https://api.kimi.com/coding/v1
# SUBAGENT_KIMI_MODEL=kimi-for-coding
# SUBAGENT_KIMI_USER_AGENT=claude-code/1.0.0
#
# MiniMax direct route. Defaults the model to MINIMAX_ANTHROPIC_MODEL if set.
# SUBAGENT_MINIMAX_BASE_URL=https://api.minimax.io/v1
# SUBAGENT_MINIMAX_MODEL=MiniMax-M3
#
# Legacy Ollama coding route (retained for back-compat; no longer the live path).
# SUBAGENT_OLLAMA_MODEL=kimi-k2.6:cloud

# Langfuse integration

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://your-custom-langfuse-url.com

# ── MCP + NeuroVault (long-term memory) ───────────────────────────────────
# When enabled, memory writes are mirrored to the NeuroVault MCP server
# and retrieval can fan out across vault.
MCP_ENABLED=true
# Client-side timeout (ms) for MCP tool calls. Must exceed the slowest sidecar's
# internal wait — browser image agents (grok_web/gemini/chatgpt) run ~300s, so
# the default 420s leaves headroom. Too low = -32001 "Request timed out" even
# though the tool succeeded server-side.
MCP_CALL_TIMEOUT_MS=420000
# claude-cli plane only: the Claude Code CLI mounts MCP servers itself and
# enforces its OWN timeouts (bypassing MCP_CALL_TIMEOUT_MS above). Both default
# to 420s in claude-cli.ts; override here only to tune. MCP_TOOL_TIMEOUT = total
# per tool call; CLAUDE_CODE_MCP_TOOL_IDLE_TIMEOUT = abort if the tool emits no
# output for this long (the binding one for silent ~304s image generation — set
# 0 to disable). MCP_TIMEOUT (server startup/connect) stays 120s.
# MCP_TOOL_TIMEOUT=420000
# CLAUDE_CODE_MCP_TOOL_IDLE_TIMEOUT=420000
NEUROVAULT_MCP_URL=
NEUROVAULT_DEFAULT_VAULT=

# ── Dream cycle (nightly memory consolidation) ────────────────────────────
DREAM_ENABLED=false
DREAM_RUN_TIME=03:00
DREAM_LOOKBACK_HOURS=24
DREAM_MODEL=

# ── Memory pipeline (auto-extraction after every assistant turn) ──────────
MEMORY_EXTRACT_MIN_CHARS=200
# Model for the extractor LLM. Defaults to VOIDAI_MODEL.
MEMORY_EXTRACT_MODEL=
# Memories below this composite score are dropped. Range 0–1.
MEMORY_IMPORTANCE_THRESHOLD=0.6
# Caps on Vault writes per session / per rolling hour. Over the cap, the
# memory still lands in the local SQLite index — only the MCP mirror is
# skipped until the window resets. Hits log to hive_mind as memory_capped.
MEMORY_PER_SESSION_MAX=50
MEMORY_PER_HOUR_MAX=200
# Bulk-import parallelism. Each worker holds one outstanding extractor LLM
# call to VoidAI. 6 is a safe default; bump if VoidAI has headroom, drop to 1
# to restore the legacy serial importer behaviour.
MEMORY_IMPORT_CONCURRENCY=6
# Auto-inject top relevant memories into every agent's system prompt so all
# providers (OpenAI/VoidAI, Anthropic API, Claude CLI, Codex CLI, Gemini CLI) get memory awareness.
MEMORY_PREINJECT_ENABLED=true
MEMORY_PREINJECT_MAX=5
MEMORY_PREINJECT_MIN_SCORE=0.45

# ── Model triage (per-task model selection) ───────────────────────────────
# When the heuristic classifier's score lands in the [low, high] borderline
# zone, fire a single cheap LLM call for a sharper decision. Disable to use
# heuristic only.
TRIAGE_LLM_ENABLED=true
TRIAGE_LLM_MODEL=
TRIAGE_BORDER_LOW=0.40
TRIAGE_BORDER_HIGH=0.55

# Budget caps. When a session/hour exceeds these token totals, triage
# downgrades high → mid (or mid → low) until the window resets.
BUDGET_SESSION_TOKENS=200000
BUDGET_HOUR_TOKENS=1000000

# ── Auto context compaction ───────────────────────────────────────────────
# When a session's history crosses either threshold, prior turns are
# summarized, saved as a session_summary memory, and replaced in-place with
# the summary + a few re-injected relevant memories.
COMPACT_ENABLED=true
# Ratio-based mode (recommended). The model's total context window (default 200k).
COMPACT_CONTEXT_WINDOW=200000
# Trigger compaction when estimated tokens exceed contextWindow * triggerRatio.
COMPACT_TRIGGER_RATIO=0.70
# After compaction, aim for contextWindow * targetRatio tokens remaining.
COMPACT_TARGET_RATIO=0.75
# Never keep fewer than this many recent turns regardless of ratios.
COMPACT_KEEP_RECENT_MIN=4
# Never compact more than this many turns in a single pass.
COMPACT_MAX_TURNS=60
# Legacy absolute thresholds (fallback when COMPACT_CONTEXT_WINDOW is 0).
COMPACT_TOKEN_THRESHOLD=8000
COMPACT_TURN_THRESHOLD=30
# Deprecated: replaced by COMPACT_KEEP_RECENT_MIN. Kept for backwards compat.
COMPACT_KEEP_RECENT=6
COMPACT_REINJECT_MEMORIES=3
# Model for the summarizer LLM. Defaults to MEMORY_EXTRACT_MODEL or VOIDAI_MODEL.
COMPACT_MODEL=
# Set to false to skip the working-state extraction LLM call on each compaction.
COMPACT_EXTRACT_WORKING_STATE=true

# ── Attachment registry (uploaded document storage) ───────────────────────
# Optional disk-mirror for binary documents uploaded via /api/chat
# (PDF / DOCX / EPUB / HTML / TXT / MD). The canonical store is always
# in-memory (30-min TTL, 50 MB / session). When enabled, each registered
# document is ALSO written to ATTACHMENT_DISK_DIR for debugging, forensics,
# and external tooling. Off by default — opt in.
ATTACHMENT_DISK_MIRROR=false
# Directory for the disk mirror. Default: <cwd>/uploads/docs
# Layout: <ATTACHMENT_DISK_DIR>/<sessionId>/<attachmentId>__<safe-name>
ATTACHMENT_DISK_DIR=
# Docuflow REST API URL — used for large file uploads (bypasses base64 truncation).
DOCUFLOW_API_URL=https://docuflow-api.your-domain.com
# Files >= this size (bytes) use the REST API route instead of base64 MCP route.
# Default: 1048576 (1 MB)
DOCUFLOW_LARGE_FILE_THRESHOLD_BYTES=1048576

# ── Heartbeat (keeps agents + MCP connections warm) ───────────────────────
# Pings every active non-temp agent on this interval with a 1-token LLM call
# so the first user message in a new session doesn't pay the cold-start tax.
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SEC=60
HEARTBEAT_MODEL=
# Claude-CLI agents use subscription quota — pinging them every minute would
# eat budget for nothing, so they're skipped by default.
HEARTBEAT_SKIP_CLAUDE_CLI=true
# When true, agents whose provider is "openrouter" are heartbeat-pinged through
# the VoidAI (OpenAI-compatible) client instead of OpenRouter. This avoids paying
# OpenRouter routing fees and is useful when VoidAI is more reliable for pings.
HEARTBEAT_OPENROUTER_VIA_VOIDAI=false
# ── Custom Ollama provider for heartbeats only ──────────────────────────────
# When HEARTBEAT_USE_OLLAMA_PROVIDER=true, ALL heartbeat pings route through
# this custom Ollama endpoint instead of per-provider routing. Good for using
# a cheap local model to keep connections warm without burning cloud quota.
HEARTBEAT_USE_OLLAMA_PROVIDER=false
HEARTBEAT_OLLAMA_API_KEY=                    # Bearer token for the Ollama endpoint
HEARTBEAT_OLLAMA_BASE_URL=https://ollama.internal.your-domain.com/v1
HEARTBEAT_OLLAMA_MODEL=llama3.2

# ── Exec tools (filesystem + shell access for agents) ─────────────────────
# Tools are gated per-agent (agents.exec_enabled column, off by default).
# Default-allow shell with a hard-deny denylist for catastrophic commands.
EXEC_TIMEOUT_MS=60000
EXEC_OUTPUT_MAX_BYTES=200000
# Comma-separated extra patterns to ALWAYS block (in addition to built-ins
# like `rm -rf /`, sudo rm, fork bombs, mkfs, dd to /dev, shutdown, curl|sh).
EXEC_BASH_DENY=
# Optional filesystem boundary. Comma-separated allow-roots; empty = no boundary.
# The workspace root and the OS tmp dir are always permitted on top of these.
# Recommended: pin to the repo root (+ /tmp) so stray writes to /etc etc. are blocked.
EXEC_ROOT=
# Default working directory for bash_run when none is provided (and workspace
# scoping is disabled — otherwise the per-agent workspace is used).
EXEC_DEFAULT_CWD=

# ── Per-agent workspace scoping ───────────────────────────────────────────
# Relocates the default home of exec tools (bash_run, fs_*, run_skill_script,
# broker /exec) to <WORKSPACE_ROOT>/<sessionId>/<agentId>/ so generated files
# land in an organized, sweepable place instead of the repo root. Relative paths
# resolve there; absolute paths still work (shared-read). This is scoping, not
# OS isolation — the EXEC_ROOT boundary above still governs what is reachable.
WORKSPACE_ENABLED=true
WORKSPACE_ROOT=./workspaces
# Reap a session's workspace when the session is gone or older than this.
WORKSPACE_TTL_HOURS=72
# Max dirs/files removed per sweep pass (mirrors CLEANUP_MAX_* throttling).
WORKSPACE_SWEEP_MAX_PER_RUN=500
# Age-based cleanup of generated uploads/ media (chat/, carbone_renders/, docs/).
# Deliverables (agent-files/), avatars/, and images/ are NEVER auto-deleted.
UPLOADS_SWEEP_ENABLED=true
UPLOADS_TTL_HOURS=336   # 14 days; 0 = disable the uploads sweep

# ── Inbound upload persistence (Discord + web GUI) ────────────────────────
# Persists every inbound upload (documents, images, audio, video, arbitrary)
# into the per-session workspace (workspaces/<session>/_uploads/) so agents can
# list/open any file via list_uploads / get_upload / analyze_image.
UPLOADS_PERSIST_ENABLED=true
UPLOADS_SESSION_MAX_MB=256   # per-session persisted-uploads cap
UPLOAD_PER_FILE_MAX_MB=50    # per-file cap; larger files recorded as a stub

# ── Vision (image inputs for agents) ─────────────────────────────────────
# When agents receive images (via dashboard chat or Discord attachments),
# NeuroClaw routes them based on the agent's vision_mode:
#   - 'native'     — pass directly to the agent's LLM (image_url block, etc.)
#   - 'preprocess' — describe the image first (via the agent's vision_provider:
#                    openrouter→Gemini by default, or hermes→Grok for the
#                    allowlist), then inject the text into the prompt so any LLM
#                    "sees" it (works for text-only models, Codex/Gemini/Claude CLI).
#   - 'auto'       — detect capability, prefer native when supported.
# Defaults below are used by 'preprocess' mode.
VISION_PROVIDER=openrouter
VISION_PROMPT=You are an expert image analyst. Your job is to produce a dense, structured text description of the provided image so that a downstream AI can fully understand its contents without seeing it.\n\nRules:\n1. TRANSCRIBE ALL VISIBLE TEXT verbatim. Preserve spelling, labels, button text, error messages, and URLs exactly as shown.\n2. DESCRIBE THE LAYOUT: list UI elements with their approximate screen position (top-left, center, bottom-right, etc.).\n3. DESCRIBE OBJECTS AND THEIR RELATIONSHIPS: what is near what, what overlaps what, what appears to be clickable vs static.\n4. FOR CODE / DIAGRAMS: reproduce the structure, indentation, arrows, and connections as faithfully as possible in ASCII or bulleted form.\n5. COLORS: only mention if they carry semantic meaning (red = error, green = success).\n6. DO NOT summarize or interpret intent. Report only what is visually present.\n7. Be exhaustive. It is better to include too much detail than too little.
# Max characters in a single image description (prevents runaway summaries).
VISION_MAX_DESCRIPTION_CHARS=8000
# Dual vision pipeline (see docs/specs/dual-vision-pipeline-spec.md)
#   VISION_OPENROUTER_MODEL -> Gemini via OpenRouter (default pipeline)
#   VISION_HERMES_MODEL     -> Grok via Hermes (allowlist agents). Use the exact xAI alias.
# Per-agent override: agents.vision_provider (NULL = inherit VISION_PROVIDER below).
VISION_OPENROUTER_MODEL=google/gemini-3.1-flash
VISION_HERMES_MODEL=grok-4

# ── Audio: TTS + transcription ───────────────────────────────────────────
# Two TTS providers. VoidAI uses the OpenAI-compatible /audio/speech endpoint
# (model=tts-1, voices: alloy, echo, fable, onyx, nova, shimmer). ElevenLabs
# is enabled per-agent (agents.tts_provider='elevenlabs') and requires a key.
# Transcription is always VoidAI's /audio/transcriptions (Whisper).
#
# Surface: dashboard chat (mic input + speaker button on assistant messages)
# and Discord (audio attachments → transcribe; replies attach .mp3 when both
# discord_bots.voice_enabled=1 AND agents.tts_enabled=1).

# Deepgram (STT / transcription). When DEEPGRAM_API_KEY is set, Deepgram
# is used for all transcription (Discord voice notes + voice channel STT).
# Falls back to VoidAI Whisper when unset.
# Get a key at https://console.deepgram.com — free tier covers light use.
# nova-3 is the best accuracy/cost ratio as of 2026.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1

VOIDAI_TTS_MODEL=tts-1
VOIDAI_TTS_VOICE=alloy
VOIDAI_TRANSCRIBE_MODEL=whisper-1
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
# Default ElevenLabs voice id (used when an agent picks 'elevenlabs' but has
# no tts_voice set). Find ids at https://api.elevenlabs.io/v1/voices.
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
# ── Kokoro TTS (internal instance via nb.your-domain.com) ───────────────
KOKORO_API_KEY=
KOKORO_BASE_URL=https://kokorotts.nb.your-domain.com/v1
# Default Kokoro voice id (used when an agent picks 'kokoro' but has no
# tts_voice set). See /v1/audio/voices on the Kokoro instance.
KOKORO_DEFAULT_VOICE_ID=af_heart
KOKORO_MODEL=kokoro
# Hermes/xAI TTS voice. See xAI docs for available voice ids.
HERMES_TTS_VOICE=default
# ── Chatterbox TTS (internal service at chatterbox.internal.your-domain.com) ─
# Real-time TTS with custom voice profiles. No API key required for the internal
# instance; set CHATTERBOX_API_KEY only if bearer auth has been added.
# model_type: base | turbo | multilingual
# exaggeration + cfg_weight: 0.0–1.0 creative/style controls (both default 0.5)
# Enabled by default (it's an internal service); set CHATTERBOX_ENABLED=false to disable.
CHATTERBOX_ENABLED=true
CHATTERBOX_BASE_URL=https://chatterbox.internal.your-domain.com
CHATTERBOX_API_KEY=
# Default voice profile (voice_key). Leave blank to use the server's default voice.
CHATTERBOX_DEFAULT_VOICE=
CHATTERBOX_MODEL_TYPE=base
CHATTERBOX_EXAGGERATION=0.5
CHATTERBOX_CFG_WEIGHT=0.5
# Hard cap on uploaded transcription audio (MB) and on synthesizable text (chars).
AUDIO_MAX_MB=25
AUDIO_MAX_TTS_CHARS=4000
# audio_cache TTL (days). The session_cleanup maintenance job deletes cached TTS
# blobs older than this, regardless of hit count (pure age-based). These blobs are
# multi-MB each and dominate DB size; they regenerate on demand. Default 7.
AUDIO_CACHE_TTL_DAYS=7

# TTS Normalizer sidecar (optional — set to enable text normalization before synthesis)
# TTS_NORMALIZER_URL=http://localhost:8082

# ── Gemini Live voice (optional — enables voice_provider=gemini_live on agents)
# API key for Google Gemini — required for Gemini Live voice sessions.
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.0-flash-live
GEMINI_LIVE_VOICE=Zephyr
GEMINI_LIVE_IDLE_TIMEOUT_MINUTES=5

# ── Memory graph extraction (entities + relationships per memory) ────────
# When enabled, the memory extractor's JSON output also captures entities
# (NeuroClaw, Composio, Discord, …) and subject/verb/object relationships,
# stored in memory_entities + memory_relationships. No new LLM call —
# folded into the existing extractor request. Disable to revert to plain
# typed memories.
MEMORY_GRAPH_EXTRACT_ENABLED=true

# ── Memory embeddings (semantic search over memory_index) ────────────────
# When enabled, every memory written to memory_index also gets a vector
# embedding. The retriever uses cosine similarity instead of Jaccard for
# rows that have an embedding (legacy rows fall back to the token path).
# Disabled by default to avoid unexpected spend on the embedding endpoint.
MEMORY_EMBEDDINGS_ENABLED=false
# Embedding model. Defaults to text-embedding-3-small. When OPENAI_API_KEY is set,
# embeddings route to OpenAI directly. Otherwise they fall back to the
# configured VoidAI client.
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# Skip the embedding call when summary length is below this many chars.
# Below ~30 chars the vector is dominated by stop-words and the cosine
# match is noisier than just falling back to the Jaccard path.
MEMORY_EMBEDDING_MIN_CHARS=30

# ── Discord-as-frontend bot (chat with NeuroClaw via Discord) ────────────
# Distinct from Composio's Discord toolkit (which lets agents POST to Discord).
# This bot is INBOUND: users @mention it in a channel and the bot routes the
# message into the NeuroClaw chat API. Run with `npm run bot:discord`.
#
# Setup: https://discord.com/developers/applications → New Application → Bot →
# enable Message Content + Server Members intents → copy the bot token here.
DISCORD_BOT_TOKEN=
# Agent name (or id) that handles mentions when no per-channel route matches.
DISCORD_DEFAULT_AGENT=Alfred
# Optional per-channel routing as JSON: { "<channel_id>": "<agent_name_or_id>" }.
# e.g. {"112233":"Coder","445566":"Researcher"}
DISCORD_CHANNEL_ROUTES=
# Optional comma-separated allowlist of Discord user IDs. When set, the bot
# ignores @mentions from any user not on the list. Empty = anyone in the
# channel can talk to the bot.
DISCORD_ALLOWED_USERS=
# Cap the bot's reply length (Discord hard limit is 2000 chars per message).
DISCORD_MAX_REPLY_CHARS=1900
# Hard cap (ms) on waiting for a single Discord chat turn. Default 300000 (5 min).
# Raise if multi-agent orchestration on long messages regularly exceeds this.
# Production currently runs at 900000 (15 min) per the Discord Bot Timeout
# Recovery spec — see src/system/discord-placeholder-monitor.ts. The monitor
# preserves the placeholder message ID across timeout and edits it with the
# final answer once the detached run completes, so the user sees a single
# coherent reply path even when the live stream times out.
DISCORD_STREAM_TIMEOUT_MS=300000
# Soft threshold (ms) before the hard timeout fires. When elapsed AND no
# tokens have streamed yet, the placeholder is edited to a durable "still
# working" notice so the user sees feedback before the abort. Defaults to 90s.
DISCORD_SOFT_TIMEOUT_MS=90000

# Voice channel joining. Bots auto-join voice channels that have a route
# configured in discord_channel_routes (same table as text channels).
# Set voice_channel_enabled=0 on a discord_bots row to disable per-bot.
VOICE_SILENCE_THRESHOLD_MS=500
VOICE_MAX_UTTERANCE_SEC=30

# ── Browser tools (Browserless: rendered HTML, screenshots, PDFs, JS) ────
# ── Browser-Use Cloud (generic browser agent) ────────────────────────────────
# When set, browser_agent connects to browser-use's stealth cloud browser
# instead of launching a local Chromium. Free tier: 15-min sessions, auto-
# provisioned per connect — no manual session management needed.
# Get a key at https://browser-use.com
BROWSER_USE_API_KEY=

# Hosted Chromium-as-a-service. Set both URL + TOKEN to enable browser_*
# tools (browser_fetch, browser_screenshot, browser_pdf, browser_run_js).
# Get a token at https://www.browserless.io/ — free tier covers light use.
BROWSERLESS_URL=
BROWSERLESS_TOKEN=
# Per-request timeout (ms) for the browserless HTTP client. Render-heavy
# pages can be slow — keep this generous.
BROWSERLESS_TIMEOUT_MS=60000
# Optional RESIDENTIAL proxy used as a FALLBACK for browserless_fetch: it tries
# a direct fetch first and only retries through this proxy when a site is
# bot-walled (Cloudflare "Just a moment", etc.). Direct fetches stay fast; the
# (slower) proxy path only fires when needed. Applied via Browserless's launch
# arg (--proxy-server).
# IMPORTANT: Chromium cannot authenticate to a SOCKS5 proxy, so this MUST be a
# NO-AUTH proxy — secure it at the network layer instead (e.g. bind it to your
# NetBird/Tailscale interface only, never 0.0.0.0). Empty = no fallback (direct
# only). Example: socks5://100.x.x.x:1080
BROWSERLESS_PROXY_URL=

# ── Provider health & cooldown layer (WS2) ────────────────────────────────
# Routing remembers provider failures: typed cooldowns (auth 5m, rate-limit
# retry-after-or-60m, billing 60m, 5xx 2m exponential) demote a provider to
# the END of the fallback chain (never removed) until the cooldown expires.
# Usage-limit windows (Claude/MiniMax 5h/weekly) at >= threshold% set a soft
# cooldown until their reset time. State survives restarts (provider_health).
PROVIDER_HEALTH_ENABLED=true
PROVIDER_HEALTH_WINDOW_THRESHOLD=95
PROVIDER_HEALTH_POLL_MINUTES=15

# ── Web search (web_search tool) ──────────────────────────────────────────
# The web_search tool resolves through a ladder:
#   1. Brave Search API (below) — official JSON, datacenter-resilient PRIMARY
#   2. SearXNG metasearch (default engines, then SEARXNG_FALLBACK_ENGINES)
#   3. Bing via headless browser (Browserless) — last resort
#
# Brave Search API — STRONGLY RECOMMENDED on datacenter IPs where SearXNG's
# scraper engines get CAPTCHA'd. Free tier: 2,000 queries/month, no card.
# Get a key: https://api-dashboard.search.brave.com/  (Data for Search → free)
# Leave blank to skip tier 1 and rely on SearXNG + browser only.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1
BRAVE_SEARCH_TIMEOUT_MS=15000

# SearXNG metasearch (fallback). Defaults to the hosted NeuroClaw instance;
# SEARXNG_ENABLED=false gates this tier off entirely.
SEARXNG_BASE_URL=https://searxng.your-domain.com
SEARXNG_ENABLED=true
SEARXNG_TIMEOUT_MS=20000
# Retry engines when the default general set (brave/ddg/startpage) is blocked
# from the server's IP and returns zero results. Reachability is time-varying,
# so fan out across several survivable engines rather than betting on one.
SEARXNG_FALLBACK_ENGINES=bing,google,brave,duckduckgo,mojeek,wikipedia,stackoverflow

# ── Composio (1000+ external app toolkits via hosted MCP) ─────────────────
# Get COMPOSIO_API_KEY from https://platform.composio.dev/settings.
# Composio is enabled per-agent via the dashboard (composio_user_id +
# composio_toolkits columns). Even with a key set, agents must be opted in.
COMPOSIO_API_KEY=
# Optional override of the Composio API base URL.
COMPOSIO_BASE_URL=
# Cache TTL (seconds) for the per-user composio.create() session before we
# re-mint. Keep modest so revoked OAuth connections drop out within the window.
COMPOSIO_SESSION_TTL_SEC=900

# ── n8n (workflow automation) ─────────────────────────────────────────────
# Used by create_n8n_workflow / list_n8n_workflows / get_n8n_workflow tools
# and by n8n_workflow cron jobs that don't supply their own baseUrl/apiKey.
# Get the API key from n8n Settings → API → Create API key.
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ── Kestra (workflow orchestration) ──────────────────────────────────────
# Used by kestra_flow cron jobs that don't supply their own baseUrl/apiKey.
# Leave KESTRA_API_KEY blank for open/unauthenticated Kestra instances.
KESTRA_BASE_URL=http://localhost:8080
KESTRA_API_KEY=

# Pydantic AI bridge — see pydantic-agents/README.md
PYDANTIC_DEEP_RESEARCH_URL=http://localhost:7100/mcp
PYDANTIC_WEB_RESEARCH_URL=http://localhost:7101/mcp
PYDANTIC_BROWSER_AGENT_PORT=7107
CHATGPT_IMAGE_AGENT_PORT=7110
CHATGPT_HEADLESS=true
# CHATGPT_PROFILE_DIR=./pydantic-agents/chatgpt_image_agent/profile
# CHATGPT_IMAGE_OUTPUT_DIR=./pydantic-agents/chatgpt_image_agent/outputs

# ── Grok web agent (grok.com Aurora, no API rate limits) ──────────────────
GROK_WEB_AGENT_PORT=7113
GROK_WEB_HEADLESS=true
# GROK_WEB_PROFILE_DIR=/root/.config/grok-web
# GROK_WEB_OUTPUT_DIR=./pydantic-agents/grok_web_agent/outputs
# Set Timezone
TZ=America/Los_Angeles

# ── LiveKit (real-time audio/video rooms) ─────────────────────────────────
# Get from LiveKit Cloud → Project Settings → API Keys
LIVEKIT_API_KEY=        # LiveKit Cloud → Project Settings → API Keys
LIVEKIT_API_SECRET=     # LiveKit Cloud → Project Settings → API Keys
LIVEKIT_URL=            # wss://your-project.livekit.cloud

# ── Dashboard notification mirror (send all dashboard notifications + approvals to Discord)
# When enabled, every agent_user_message, approval request, and analyst alert that
# appears in the dashboard is also posted to the configured Discord channel.
# NOTIFY_DISCORD_CHANNEL_ID defaults to ALERT_DISCORD_CHANNEL_ID if not set.
NOTIFY_DISCORD_ENABLED=false
NOTIFY_DISCORD_CHANNEL_ID=
NOTIFY_DISCORD_BOT_ID=

# Sub-agent parallel execution
# Use kimi-k2:6 (Ollama) instead of claude-opus-4 / gpt-5.5 at frontier tier
PREFER_KIMI_FRONTIER=false
# Max tokens injected as context into a sub-agent (prevents parent history bleed).
# 2000 (~8KB) starved code tasks; 8000 (~32KB) fits a real file or diff.
SUB_AGENT_CONTEXT_LIMIT=8000
# SUB_AGENT_MAX_CONCURRENT=20     # Global cap on concurrent orchestration steps per process (default: 20)

# ── Sub-agent tool lockdown ────────────────────────────────────────────────
# Comma-separated tools blocked for sub-agents (spawnDepth >= 1).
# fs_read is blocked by default — pass it via allowedToolOverrides at spawn time
# if a sub-agent legitimately needs it (e.g. code-review tasks).
# SUB_AGENT_BLOCKED_TOOLS=fs_write,fs_read,fs_list,fs_search,bash_run,write_vault_note,manage_task,manage_project,spawn_agent,assign_task_to_agent,schedule_job,delete_job,update_job,discord_register_bot,discord_remove_bot

# ── Decomposer tuning ──────────────────────────────────────────────────────
# Token budget for the task decomposition LLM call (default 900 — up from 350).
# DECOMPOSER_MAX_TOKENS=900
# Token budget for the second-chance yes/no complexity retry.
# DECOMPOSER_RETRY_MAX_TOKENS=32

# ── Tool manifest for small-context models ──────────────────────────────
# When enabled, only core tool schemas are sent to the LLM on the first turn.
# All other tools appear as a lightweight manifest in the system prompt.
# If the assistant mentions a tool name in its reasoning, the full schema is
# injected on the next turn (on-demand). Disable to always send full schemas.
TOOL_MANIFEST_ENABLED=true
# Comma-separated list of model names (substrings) to restrict manifest mode.
# Example: "kimi,llama3.2" enables manifest only for models matching those strings.
# Leave empty to enable for ALL models (default).
TOOL_MANIFEST_MODELS=
# Override the default "core" tool set that always ships with full schemas.
# Default: search_memory,write_vault_note,message_agent,notify_user,manage_task,find_tasks,bash_run,fs_read,fs_write,browserless_fetch,save_session_summary,compact_context,run_subtask,spawn_agent
TOOL_MANIFEST_CORE_TOOLS=


# ── Dashboard chat reliability (v3.2) ─────────────────────────────────────
# Structured heartbeat + resumable runs replace the silent 15s `:` keepalive.
# Heartbeat cadence — also the runs.last_heartbeat_at write interval.
DASHBOARD_HEARTBEAT_INTERVAL_MS=10000
# When true, a browser tab close / network blip does NOT kill the agent loop.
# The run is marked 'detached'; partial output continues accumulating in the
# DB; a reconnect via /api/chat/resume picks up where it left off. Set to
# false for legacy abort-on-disconnect behavior.
DASHBOARD_CHAT_DETACH_ON_DISCONNECT=true
# Background sweep: any run whose heartbeat hasn't ticked in this long is
# flipped from 'running'/'detached' to 'dropped'. Default 10 min.
AGENT_RUN_STALE_MS=600000
# Reserved knob; currently piggy-backs on DASHBOARD_HEARTBEAT_INTERVAL_MS.
AGENT_RUN_CHECKPOINT_INTERVAL_MS=30000
# Auto-fallback timeout for synchronous message_agent calls (Sprint 3).
MESSAGE_AGENT_SYNC_TIMEOUT_MS=90000


# ── NC Broker (secrets broker, spec v3) ───────────────────────────────────
# The broker mediates every agent's access to credentials. Agents reference
# secrets by name; values are injected at call time. See:
#   docs/specs/nc-broker-v3.md
#
# Storage backend selector. Two options:
#   env-manager  - secrets live in this .env (default; no encryption-at-rest)
#   infisical    - self-hosted Infisical via docker-compose (encrypted, audited)
# Run `docker compose up -d infisical` then complete the setup runbook in
# docker-compose.yml before flipping to "infisical".
NC_BROKER_STORAGE=env-manager

# HMAC-SHA256 key for agent session tokens (32 raw bytes, base64-encoded).
# Generate with: openssl rand -base64 32  (or run: npm run broker:bootstrap)
# Auto-created at .nc-broker-hmac-key on first boot if absent — copy that
# value here for production and into 1Password as backup.
NC_BROKER_HMAC_KEY=

# HMAC secret for verifying inbound /rotation-webhook requests from Infisical.
# Required ONLY if you wire Infisical -> broker rotation webhooks. Generate
# with: openssl rand -hex 32. Without it the webhook endpoint refuses all
# requests (broker.admin/rotation-test still works for manual triggers).
NC_BROKER_WEBHOOK_SECRET=

# ── Infisical connection (only when NC_BROKER_STORAGE=infisical) ─────────
# Site URL of the Infisical instance. Set to your managed/hosted instance, or
# leave at the docker-compose default if you ran `docker compose up infisical`.
NC_BROKER_INFISICAL_SITE_URL=https://infisical.your-domain.com
# Machine-identity Universal Auth credentials. Create in Infisical UI:
#   Project Settings -> Access Control -> Machine Identities -> "nc-broker"
#   then under that identity -> Auth Methods -> Universal Auth -> create
#   client secret. Both values are shown ONCE at creation time.
NC_BROKER_INFISICAL_CLIENT_ID=
NC_BROKER_INFISICAL_CLIENT_SECRET=
# Project UUID — copy from the Infisical URL after you open the project:
#   /projects/<UUID>/secrets/...
NC_BROKER_INFISICAL_PROJECT_ID=
# Environment slug (Infisical defaults: dev / staging / prod). Broker writes
# all secrets to ONE environment.
NC_BROKER_INFISICAL_ENVIRONMENT=prod
# Folder path inside the environment. Most setups want the root "/".
NC_BROKER_INFISICAL_PATH=/

# ── Infisical SELF-HOSTED container vars (only for docker-compose.yml) ───
# Skip this block entirely if you're using a managed/hosted Infisical.
# Encryption key for at-rest secret values (16 raw bytes hex).
#   openssl rand -hex 16
INFISICAL_ENCRYPTION_KEY=
# JWT signing secret for Infisical's own auth (base64, 32+ bytes).
#   openssl rand -base64 32
INFISICAL_AUTH_SECRET=
# Postgres password used by both the Infisical container and infisical-db.
#   openssl rand -base64 24
INFISICAL_DB_PASSWORD=
# Public-facing URL of Infisical (browser + SDK both target this). Match the
# loopback port from docker-compose.yml.
INFISICAL_SITE_URL=http://localhost:8222

# ── Curator (nightly memory backstop) ───────────────────────────────────────
CURATOR_ENABLED=true
CURATOR_RUN_TIME=02:00
CURATOR_CONCURRENCY=3
CURATOR_MAX_SESSIONS_PER_RUN=100

# ── Session cleanup ─────────────────────────────────────────────────────────
CLEANUP_COMMS_MIN_HOURS=24
CLEANUP_HARD_CAP_HOURS=54
CLEANUP_MAX_EXTRACT_PER_RUN=25

# ── Agent inbox ─────────────────────────────────────────────────────────────
AGENT_INBOX_ENABLED=true

# ── Autonomous Mission Control loop ──────────────────────────────────
# On-demand self-driving loop (start/stop via /api/autonomous/* or the
# `autonomous_mode` tool). It keeps pulling the next `todo` task off the
# board, runs each through the agent_task pipeline, and reports back when
# the board is empty (the natural stop — it drains the WHOLE project).
# MAX_TASKS / MAX_MINUTES = 0 mean unlimited (drain everything); set a
# positive value only if you want a short, capped run. The real runaway
# guard is MAX_CONSECUTIVE_FAILURES (stops on systemic breakage), which
# never penalises a big, healthy board.
AUTONOMOUS_MAX_TASKS=0
AUTONOMOUS_MAX_MINUTES=0
AUTONOMOUS_MAX_CONSECUTIVE_FAILURES=3
AUTONOMOUS_PER_TASK_TIMEOUT_MS=1200000
# Stale guard: skip todo tasks created more than N days ago so the loop never
# churns through weeks-old junk. 0 = no age limit (work tasks of any age).
# Can also be overridden per run via /api/autonomous/start {maxTaskAgeDays}.
AUTONOMOUS_MAX_TASK_AGE_DAYS=0
# Fallback agent (by name) for tasks with no resolvable assignee.
AUTONOMOUS_DEFAULT_AGENT=Alfred

# ── Sentinel ─────────────────────────────────────────────────────────
# SENTINEL_USE_VOIDAI=true routes Sentinel's check-in LLM calls through
# VoidAI (OpenAI-compat) instead of the Claude CLI path, isolating
# background check-ins from the global Claude concurrency gate and
# timeout. See specs/claude-code-abort-fix.md Fix 2 (Option B).
SENTINEL_USE_VOIDAI=true
SENTINEL_MODEL=gpt-4o-mini

# Sentinel liveness overhaul
TASK_LIVENESS_WINDOW_MIN=3            # how recent a heartbeat counts as "alive" (min)
SENTINEL_USE_LIVENESS_READ=true       # kill-switch: false reverts to legacy LLM check-in
SENTINEL_ESCALATION_COOLDOWN_MS=900000 # min gap between escalations per task (15m)
SENTINEL_SEND_NUDGE=true              # optional courtesy LLM nudge before reassign

# ── Antigravity (Google — multi-model via agy CLI) ────────────────────────────
# Install: https://antigravity.dev  — run `agy` once to log in via Google OAuth.
# Auth is managed by the agy binary; NeuroClaw just spawns it as a subprocess.
# Use /usage inside agy to check quota; /models to list available models.
# ANTIGRAVITY_CLI_COMMAND=agy       # path or name of the agy binary
# ANTIGRAVITY_SETTINGS_DIR=         # override ~/.gemini/antigravity-cli dir
ANTIGRAVITY_MODEL=antigravity/gemini-3.5-flash-high
ANTIGRAVITY_TIMEOUT_MS=900000
ANTIGRAVITY_CONCURRENCY_LIMIT=1
# Persistent tmux REPL mode for agy agents (default: true). Set to false to use
# the stateless `agy --print` path instead.
ANTIGRAVITY_TMUX_ENABLED=true
# Minutes before an idle agy tmux session is reaped (default: 30)
ANTIGRAVITY_SESSION_TTL_MINUTES=30

# ── Discord stream timeout ─────────────────────────────────────────────────
# Raise from default 300s to 900s to reduce timeout failures on complex turns.
# DISCORD_STREAM_TIMEOUT_MS=900000
# Soft threshold at which the bot posts "still working" before the hard timeout.
# DISCORD_SOFT_TIMEOUT_MS=90000

# Stephanie analyst — schedule (Mon + Thu 9AM by default)
STEPHANIE_CRON=0 9 * * 1,4

# ── Inngest (durable job queue) ──────────────────────────────────────────────
# Self-hosted Inngest server reached at a public URL. Event/signing keys are
# pulled from Infisical (INGEST_EVENT_KEY / INGEST_SIGNING_KEY) via the broker —
# do NOT put them in .env. INNGEST_ENABLED: false=legacy SQLite queue |
# dual=SQLite + Inngest events (Phase 1 verify) | true=Inngest-only (Phase 2).
# INNGEST_ENABLED=false
# INNGEST_BASE_URL=https://inngest.your-domain.com          # NeuroClaw → Inngest (send)
# INNGEST_SERVE_URL=https://neuroclaw.your-domain.com/api/inngest  # Inngest → NeuroClaw (callback)

# ── Interactive Claude (tmux REPL — normal-pool billing) ─────────────────────
# CLAUDE_INTERACTIVE_ENABLED=false        # true to enable provider='claude-interactive'
# CLAUDE_INTERACTIVE_RUN_USER=            # optional non-root user to run `claude` as
# CLAUDE_INTERACTIVE_IDLE_REAP_MIN=10     # kill idle tmux sessions after N minutes
# CLAUDE_INTERACTIVE_TURN_TIMEOUT_MS=600000   # per-turn await timeout
# CLAUDE_INTERACTIVE_MAX_SESSION_MS=3600000   # absolute hard-kill age per session

# ── Knowledge Base (Supabase RAG) ─────────────────────────────────────────
KB_ENABLED=false                 # turn on the native knowledge base tools
SUPABASE_URL=                    # self-hosted Supabase gateway, e.g. http://<host>:8000
SUPABASE_SERVICE_KEY=            # self-hosted service_role JWT (SERVICE_ROLE_KEY)
KB_DB_SCHEMA=neuroclaw_kb        # dedicated schema; must be in PGRST_DB_SCHEMAS on the server
KB_EMBEDDING_MODEL=text-embedding-3-small  # MUST match the KB's existing embedded vectors
KB_CHUNK_MAX_CHARS=2000          # ~500 tokens per chunk
KB_CRAWL4AI_URL=http://127.0.0.1:7105/mcp
KB_MATCH_COUNT=5
# NOTE: KB requires MEMORY_EMBEDDINGS_ENABLED=true (boot fails loud otherwise).
# NOTE: the neuroclaw_kb schema must be exposed via PGRST_DB_SCHEMAS + restart on the Supabase server.

# Memory store backend: sqlite (local, default) or supabase (neuroclaw_kb pgvector,
# same schema/client as the KB). Requires MEMORY_EMBEDDINGS_ENABLED=true when supabase.
MEMORY_BACKEND=sqlite
