VOIDAI_API_KEY=sk-voidai-your-key
VOIDAI_BASE_URL=https://api.voidai.app/v1
VOIDAI_MODEL=gpt-5.1

DASHBOARD_PORT=3141
DASHBOARD_TOKEN=change-me

DB_PATH=./neuroclaw.db

# Auto-delegation: LLM classifies which agent best fits each message
AUTO_DELEGATION_ENABLED=false
AUTO_DELEGATION_MIN_CONFIDENCE=0.65
ROUTER_MODEL=

# Temporary agent spawning
SPAWN_AGENTS_ENABLED=false
TEMP_AGENTS_AUTO_APPROVE=true
TEMP_AGENT_TTL_HOURS=6
TEMP_AGENT_IDLE_TIMEOUT_MINUTES=30
TEMP_AGENT_SOFT_LIMIT=10
TEMP_AGENT_HARD_LIMIT=25

# Claude / Anthropic integration
# Preferred: API key from https://console.anthropic.com (billed per-token).
# If left blank, the app falls back to the OAuth credentials stored by the
# `claude` CLI at ~/.claude/.credentials.json (your Pro/Max subscription).
# The fallback is intended for local personal use only — Anthropic does not
# permit subscription auth in shipped products.
ANTHROPIC_API_KEY=

# Langfuse integration

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://your-custom-langfuse-url.com