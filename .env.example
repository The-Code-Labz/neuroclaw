VOIDAI_API_KEY=sk-voidai-your-key
VOIDAI_BASE_URL=https://api.voidai.app/v1
VOIDAI_MODEL=gpt-5.1

DASHBOARD_PORT=3141
DASHBOARD_TOKEN=change-me

DB_PATH=./neuroclaw.db

# Auto-delegation: LLM classifies which agent best fits each message
AUTO_DELEGATION_ENABLED=false
AUTO_DELEGATION_MIN_CONFIDENCE=0.65
ROUTER_MODEL=

# Temporary agent spawning
SPAWN_AGENTS_ENABLED=false
TEMP_AGENTS_AUTO_APPROVE=true
TEMP_AGENT_TTL_HOURS=6
TEMP_AGENT_IDLE_TIMEOUT_MINUTES=30
TEMP_AGENT_SOFT_LIMIT=10
TEMP_AGENT_HARD_LIMIT=25

# Claude / Anthropic integration
# Backend selector: "claude-cli" (default) routes Claude calls through the local
# `claude` CLI (subscription auth, no API key needed). "anthropic-api" uses the
# direct Anthropic SDK + ANTHROPIC_API_KEY (billed per-token).
# There is NO silent fallback between them.
CLAUDE_BACKEND=claude-cli
CLAUDE_CLI_COMMAND=claude
CLAUDE_MAX_TURNS=20
CLAUDE_TIMEOUT_MS=900000

# Concurrency + retry for the claude-cli backend (subscription auth has tight
# per-window limits, so we serialize calls by default).
CLAUDE_CONCURRENCY_LIMIT=1
CLAUDE_RETRY_MAX=2
CLAUDE_RETRY_BASE_MS=3000

# Required only when CLAUDE_BACKEND=anthropic-api. Get from https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ── Codex (OpenAI / ChatGPT subscription via local `codex` CLI) ───────────
# Backend selector: "cli" (default) routes through your local `codex` binary
# using the ChatGPT subscription credentials at ~/.codex/auth.json.
# "api" uses OPENAI_API_KEY directly via the OpenAI SDK (per-token billing).
CODEX_BACKEND=cli
CODEX_CLI_COMMAND=codex
CODEX_TIMEOUT_MS=900000
CODEX_CONCURRENCY_LIMIT=1
# Sandbox policy when Codex executes shell commands (read-only is safest).
# Allowed: read-only | workspace-write | danger-full-access
CODEX_SANDBOX_MODE=read-only

# Langfuse integration

LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://your-custom-langfuse-url.com

# ── MCP + NeuroVault (long-term memory) ───────────────────────────────────
# When enabled, memory writes are mirrored to the NeuroVault MCP server
# and retrieval can fan out across vault/researchlm/insightslm.
MCP_ENABLED=true
NEUROVAULT_MCP_URL=https://n8n.neurolearninglabs.com/mcp/vaultmind-mcp
NEUROVAULT_DEFAULT_VAULT=neuroclaw

# Optional knowledge MCPs — leave blank to disable
RESEARCHLM_MCP_URL=
INSIGHTSLM_MCP_URL=
# Each server exposes its own set of tools — fan-out only fires when this env
# names a real tool on the server (probe with the dashboard MCP probe button).
# Common choices for the n8n NotebookLM server: 'rag_chat' or 'web_search'.
RESEARCHLM_SEARCH_TOOL=
INSIGHTSLM_SEARCH_TOOL=

# ── Dream cycle (nightly memory consolidation) ────────────────────────────
DREAM_ENABLED=false
DREAM_RUN_TIME=03:00
DREAM_LOOKBACK_HOURS=24
DREAM_MODEL=

# ── Memory pipeline (auto-extraction after every assistant turn) ──────────
MEMORY_EXTRACT_MIN_CHARS=200
# Model for the extractor LLM. Defaults to VOIDAI_MODEL.
MEMORY_EXTRACT_MODEL=
# Memories below this composite score are dropped. Range 0–1.
MEMORY_IMPORTANCE_THRESHOLD=0.6
# Caps on Vault writes per session / per rolling hour. Over the cap, the
# memory still lands in the local SQLite index — only the MCP mirror is
# skipped until the window resets. Hits log to hive_mind as memory_capped.
MEMORY_PER_SESSION_MAX=50
MEMORY_PER_HOUR_MAX=200
# Auto-inject top relevant memories into every agent's system prompt so all
# providers (OpenAI/VoidAI, Anthropic API, Claude CLI) get memory awareness.
MEMORY_PREINJECT_ENABLED=true
MEMORY_PREINJECT_MAX=5

# ── Model triage (per-task model selection) ───────────────────────────────
# When the heuristic classifier's score lands in the [low, high] borderline
# zone, fire a single cheap LLM call for a sharper decision. Disable to use
# heuristic only.
TRIAGE_LLM_ENABLED=true
TRIAGE_LLM_MODEL=
TRIAGE_BORDER_LOW=0.40
TRIAGE_BORDER_HIGH=0.55

# Budget caps. When a session/hour exceeds these token totals, triage
# downgrades high → mid (or mid → low) until the window resets.
BUDGET_SESSION_TOKENS=200000
BUDGET_HOUR_TOKENS=1000000

# ── Auto context compaction ───────────────────────────────────────────────
# When a session's history crosses either threshold, prior turns are
# summarized, saved as a session_summary memory, and replaced in-place with
# the summary + a few re-injected relevant memories.
COMPACT_ENABLED=true
COMPACT_TOKEN_THRESHOLD=8000
COMPACT_TURN_THRESHOLD=30
COMPACT_KEEP_RECENT=6
COMPACT_REINJECT_MEMORIES=3
# Model for the summarizer LLM. Defaults to MEMORY_EXTRACT_MODEL or VOIDAI_MODEL.
COMPACT_MODEL=

# ── Heartbeat (keeps agents + MCP connections warm) ───────────────────────
# Pings every active non-temp agent on this interval with a 1-token LLM call
# so the first user message in a new session doesn't pay the cold-start tax.
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_SEC=60
HEARTBEAT_MODEL=
# Claude-CLI agents use subscription quota — pinging them every minute would
# eat budget for nothing, so they're skipped by default.
HEARTBEAT_SKIP_CLAUDE_CLI=true

# ── Exec tools (filesystem + shell access for agents) ─────────────────────
# Tools are gated per-agent (agents.exec_enabled column, off by default).
# Default-allow shell with a hard-deny denylist for catastrophic commands.
EXEC_TIMEOUT_MS=60000
EXEC_OUTPUT_MAX_BYTES=200000
# Comma-separated extra patterns to ALWAYS block (in addition to built-ins
# like `rm -rf /`, sudo rm, fork bombs, mkfs, dd to /dev, shutdown, curl|sh).
EXEC_BASH_DENY=
# Optional filesystem boundary. Empty = no boundary (anywhere your user can read/write).
EXEC_ROOT=
# Default working directory for bash_run when none is provided.
EXEC_DEFAULT_CWD=

# ── Vision (image inputs for agents) ─────────────────────────────────────
# When agents receive images (via dashboard chat or Discord attachments),
# NeuroClaw routes them based on the agent's vision_mode:
#   - 'native'     — pass directly to the agent's LLM (image_url block, etc.)
#   - 'preprocess' — describe via VISION_MODEL first, then send the text
#                    description to the agent (universal fallback; works for
#                    text-only models, Codex CLI, Claude CLI, etc.)
#   - 'auto'       — detect capability, prefer native when supported.
# Defaults below are used by 'preprocess' mode.
VISION_MODEL=gpt-4o
VISION_PROVIDER=voidai
VISION_PROMPT=Describe this image in detail, including text, objects, layout, and any notable visual elements. Be concise but complete — your description is the only context an LLM will see.
# Max characters in a single image description (prevents runaway summaries).
VISION_MAX_DESCRIPTION_CHARS=2000

# ── Audio: TTS + transcription ───────────────────────────────────────────
# Two TTS providers. VoidAI uses the OpenAI-compatible /audio/speech endpoint
# (model=tts-1, voices: alloy, echo, fable, onyx, nova, shimmer). ElevenLabs
# is enabled per-agent (agents.tts_provider='elevenlabs') and requires a key.
# Transcription is always VoidAI's /audio/transcriptions (Whisper).
#
# Surface: dashboard chat (mic input + speaker button on assistant messages)
# and Discord (audio attachments → transcribe; replies attach .mp3 when both
# discord_bots.voice_enabled=1 AND agents.tts_enabled=1).
VOIDAI_TTS_MODEL=tts-1
VOIDAI_TTS_VOICE=alloy
VOIDAI_TRANSCRIBE_MODEL=whisper-1
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
# Default ElevenLabs voice id (used when an agent picks 'elevenlabs' but has
# no tts_voice set). Find ids at https://api.elevenlabs.io/v1/voices.
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Hard cap on uploaded transcription audio (MB) and on synthesizable text (chars).
AUDIO_MAX_MB=25
AUDIO_MAX_TTS_CHARS=4000

# ── Memory graph extraction (entities + relationships per memory) ────────
# When enabled, the memory extractor's JSON output also captures entities
# (NeuroClaw, Composio, Discord, …) and subject/verb/object relationships,
# stored in memory_entities + memory_relationships. No new LLM call —
# folded into the existing extractor request. Disable to revert to plain
# typed memories.
MEMORY_GRAPH_EXTRACT_ENABLED=true

# ── Memory embeddings (semantic search over memory_index) ────────────────
# When enabled, every memory written to memory_index also gets a vector
# embedding. The retriever uses cosine similarity instead of Jaccard for
# rows that have an embedding (legacy rows fall back to the token path).
# Disabled by default to avoid unexpected spend on the embedding endpoint.
MEMORY_EMBEDDINGS_ENABLED=false
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# Skip the embedding call when summary length is below this many chars.
# Below ~30 chars the vector is dominated by stop-words and the cosine
# match is noisier than just falling back to the Jaccard path.
MEMORY_EMBEDDING_MIN_CHARS=30

# ── Discord-as-frontend bot (chat with NeuroClaw via Discord) ────────────
# Distinct from Composio's Discord toolkit (which lets agents POST to Discord).
# This bot is INBOUND: users @mention it in a channel and the bot routes the
# message into the NeuroClaw chat API. Run with `npm run bot:discord`.
#
# Setup: https://discord.com/developers/applications → New Application → Bot →
# enable Message Content + Server Members intents → copy the bot token here.
DISCORD_BOT_TOKEN=
# Agent name (or id) that handles mentions when no per-channel route matches.
DISCORD_DEFAULT_AGENT=Alfred
# Optional per-channel routing as JSON: { "<channel_id>": "<agent_name_or_id>" }.
# e.g. {"112233":"Coder","445566":"Researcher"}
DISCORD_CHANNEL_ROUTES=
# Optional comma-separated allowlist of Discord user IDs. When set, the bot
# ignores @mentions from any user not on the list. Empty = anyone in the
# channel can talk to the bot.
DISCORD_ALLOWED_USERS=
# Cap the bot's reply length (Discord hard limit is 2000 chars per message).
DISCORD_MAX_REPLY_CHARS=1900

# ── Composio (1000+ external app toolkits via hosted MCP) ─────────────────
# Get COMPOSIO_API_KEY from https://platform.composio.dev/settings.
# Composio is enabled per-agent via the dashboard (composio_user_id +
# composio_toolkits columns). Even with a key set, agents must be opted in.
COMPOSIO_API_KEY=
# Optional override of the Composio API base URL.
COMPOSIO_BASE_URL=
# Cache TTL (seconds) for the per-user composio.create() session before we
# re-mint. Keep modest so revoked OAuth connections drop out within the window.
COMPOSIO_SESSION_TTL_SEC=900