{
  "name": "neuroclaw-v1",
  "version": "1.1.0",
  "description": "NeuroClaw v1 — multi-agent registry, delegation, task assignment, and local dashboard",
  "type": "commonjs",
  "bin": {
    "nclaw": "dist/cli-code.js",
    "nc-broker": "bin/nc-broker"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dashboard": "bash scripts/dashboard.sh",
    "dev:cli": "tsx src/index.ts",
    "code": "tsx src/cli-code.ts",
    "dashboard:once": "tsx src/dashboard/server.ts",
    "skills:sync": "tsx scripts/sync-skill-exports.ts",
    "skills:add": "sh -c 'npx skills add \"$@\" && npm run skills:sync' --",
    "mcp:stdio": "tsx src/mcp/stdio-server.ts",
    "mcp:stdio:built": "node dist/mcp/stdio-server.js",
    "build": "tsc && mkdir -p dist/workflows/defaults && cp src/workflows/defaults/*.yaml dist/workflows/defaults/",
    "build:dashboard": "vite build --config src/dashboard/v2/vite.config.ts",
    "build:dashboard:v4": "vite build --config src/dashboard/v4/vite.config.ts",
    "start": "node dist/index.js",
    "check:claude": "tsx src/diagnostics/claude-check.ts",
    "check:memory": "tsx src/diagnostics/memory-check.ts",
    "doctor": "tsx src/doctor/index.ts",
    "doctor:fix": "tsx src/doctor/index.ts --fix",
    "broker:bootstrap": "node bin/nc-broker bootstrap",
    "broker:status": "node bin/nc-broker keyring-status",
    "test:broker": "tsx tests/broker/run-all.ts",
    "test:snapshot": "tsx --test src/tools/tool-schemas.snapshot.test.ts",
    "bot:discord": "tsx src/integrations/discord-bot.ts",
    "bot:discord:watch": "tsx watch src/integrations/discord-bot.ts",
    "pydantic:install": "cd pydantic-agents && python -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "pydantic:run": "cd pydantic-agents && ./run-all.sh",
    "docs": "typedoc",
    "docs:check": "tsx scripts/docs-freshness.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@composio/core": "^0.10.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@google/genai": "^2.0.1",
    "@hono/node-server": "^1.12.0",
    "@infisical/sdk": "^5.0.2",
    "@mozilla/readability": "^0.6.0",
    "@openai/agents": "^0.11.6",
    "@supabase/supabase-js": "^2.108.2",
    "better-sqlite3": "^11.1.2",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.3.0",
    "hono": "^4.5.0",
    "inngest": "^4.5.0",
    "jimp": "^0.22.12",
    "jsdom": "^29.1.1",
    "langfuse": "^3.38.20",
    "livekit-client": "^2.18.9",
    "livekit-server-sdk": "^2.15.2",
    "marked": "^18.0.4",
    "nanoid": "^3.3.7",
    "node-cron": "^4.2.1",
    "openai": "^4.52.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^5.1.0",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.4",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.14"
  }
}
