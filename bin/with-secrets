#!/usr/bin/env bash
# bin/with-secrets — fail-closed shell wrapper for broker-injected secrets
# (spec v3 §14 / §13 Phase 5).
#
# Usage:
#   with-secrets <NAME1> [NAME2 ...] -- <command> [args...]
#
# Behaviour:
#   1. Require NC_AGENT_TOKEN in the env (caller must mint one first via
#      `nc-broker mint-token --agent <Name>` or via the broker admin API).
#   2. POST {target_mcp:"shell", secrets:[...]} to /api/broker/agent/inject.
#   3. Export each returned secret value into the current shell.
#   4. Exec the user-supplied command; env is GC'd with the subshell.
#
# Fails closed: any non-200 from the broker, missing token, or empty value
# aborts before the user command runs. Exits with a distinct code per failure
# class so scripts can branch.
#
#   0   → success (replaced by exec'd command)
#   2   → bad CLI shape
#   3   → NC_AGENT_TOKEN not set
#   4   → broker returned an error
#   5   → broker returned no env / unexpected shape
#   6   → required external tool (curl / jq) missing
set -euo pipefail

DASHBOARD_PORT="${DASHBOARD_PORT:-3141}"
DASHBOARD_TOKEN="${DASHBOARD_TOKEN:-}"
BROKER_URL="${NC_BROKER_URL:-http://127.0.0.1:${DASHBOARD_PORT}}"

usage() {
  cat <<EOF >&2
Usage: with-secrets <NAME1> [NAME2 ...] -- <command> [args...]

Requires NC_AGENT_TOKEN in the env (mint via 'nc-broker mint-token --agent <Name>').
Optional: NC_BROKER_URL (default: http://127.0.0.1:3141)
          DASHBOARD_TOKEN (required — same value the broker checks)
EOF
}

# ── Dependency checks ────────────────────────────────────────────────────
for tool in curl jq; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "with-secrets: required tool '$tool' not on PATH" >&2
    exit 6
  fi
done

if [[ $# -lt 3 ]]; then
  usage
  exit 2
fi

# ── Parse: collect secret names up to '--' ───────────────────────────────
SECRETS=()
while [[ $# -gt 0 ]]; do
  if [[ "$1" == "--" ]]; then
    shift
    break
  fi
  SECRETS+=("$1")
  shift
done

if [[ ${#SECRETS[@]} -eq 0 ]]; then
  echo "with-secrets: at least one secret name required before --" >&2
  usage
  exit 2
fi
if [[ $# -eq 0 ]]; then
  echo "with-secrets: command required after --" >&2
  usage
  exit 2
fi

# ── Auth check (fail-closed) ─────────────────────────────────────────────
if [[ -z "${NC_AGENT_TOKEN:-}" ]]; then
  echo "with-secrets: NC_AGENT_TOKEN not set (fail-closed)" >&2
  exit 3
fi
if [[ -z "$DASHBOARD_TOKEN" ]]; then
  echo "with-secrets: DASHBOARD_TOKEN not set (broker requires it on /api/*)" >&2
  exit 3
fi

# ── Build JSON body { target_mcp:"shell", secrets:[...] } ────────────────
JSON_SECRETS=$(printf '%s\n' "${SECRETS[@]}" | jq -R . | jq -s .)
BODY=$(jq -n --argjson secrets "$JSON_SECRETS" '{target_mcp:"shell", secrets:$secrets}')

# ── Call broker /inject ──────────────────────────────────────────────────
RESP=$(curl -fsSL \
  -X POST "$BROKER_URL/api/broker/agent/inject" \
  -H "Authorization: Bearer $NC_AGENT_TOKEN" \
  -H "x-dashboard-token: $DASHBOARD_TOKEN" \
  -H "content-type: application/json" \
  -d "$BODY" 2>/dev/null) || {
  echo "with-secrets: broker request failed (HTTP error)" >&2
  exit 4
}

if echo "$RESP" | jq -e '.error' >/dev/null 2>&1; then
  ERR=$(echo "$RESP" | jq -r '.error')
  echo "with-secrets: broker error: $ERR" >&2
  exit 4
fi
if ! echo "$RESP" | jq -e '.env' >/dev/null 2>&1; then
  echo "with-secrets: broker response missing 'env' field" >&2
  exit 5
fi

# ── Export each secret into the current shell ────────────────────────────
# jq's '@sh' filter quotes values safely for `eval`.
eval "$(echo "$RESP" | jq -r '.env | to_entries[] | "export \(.key)=\(.value | @sh)"')"

# Clear the request token so the child can't replay it.
unset NC_AGENT_TOKEN

# ── Exec user command — env disappears with the subshell at process exit ─
exec "$@"
